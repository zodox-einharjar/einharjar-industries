# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/eve_app

# EVE SSO — register at https://developers.eveonline.com/
EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
EVE_CALLBACK_URL=http://localhost:8000/auth/callback

# Path to Fuzzwork SDE SQLite — download from https://www.fuzzwork.co.uk/dump/
SDE_PATH=data/sqlite-latest.sqlite
